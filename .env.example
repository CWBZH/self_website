NEXT_PUBLIC_SITE_URL=http://106.52.232.205:3001

# Studio owner login. Use a strong value in production.
STUDIO_PASSWORD=change-me
# Optional and preferred for production. Generate with:
# npm run studio:hash -- "your strong password"
# STUDIO_PASSWORD_HASH=
STUDIO_SESSION_SECRET=change-me-to-a-long-random-string
STUDIO_COOKIE_SECURE=false

# Optional. If omitted, comments and room messages use data/personal-room.json.
PERSONAL_ROOM_DATABASE_URL=postgresql://user:password@127.0.0.1:5432/personal_room

# Optional. Studio-only server-side translation.
# The app also falls back to AI_WORKFLOW_LLM_* if these are omitted.
TRANSLATION_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
TRANSLATION_MODEL=doubao-seed-2-0-mini-260215
TRANSLATION_API_KEY=fill-real-key-on-server-only
