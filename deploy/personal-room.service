[Unit]
Description=Personal Room Next.js site
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/apps/personal-room
EnvironmentFile=/home/ubuntu/apps/personal-room/.env.production
Environment=NODE_ENV=production
ExecStart=/usr/bin/npm run start -- --hostname 0.0.0.0 --port 3001
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
